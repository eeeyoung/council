# --- LLM Provider Toggle ---
# Set to 'ds' for DeepSeek or 'gem' for Gemini
AI_PROVIDER=ds
# DeepSeek models: deepseek/deepseek-chat (V3, default), deepseek/deepseek-reasoner (R1)
# Gemini models: gemini/gemini-2.5-flash-lite, gemini/gemini-2.5-pro, etc.
MODEL=deepseek/deepseek-chat
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ChromaDB Embeddings ---
# ChromaDB defaults to all-MiniLM-L6-v2 (local, no API key needed).
# Only set this if you need Google embeddings — requires a valid GEMINI_API_KEY.
# EMBEDDINGS_GOOGLE_GENERATIVE_AI_MODEL_NAME=gemini-embedding-001

# --- Tavily Search ---
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- crewAI Settings ---
CREWAI_TRACING_ENABLED=false
